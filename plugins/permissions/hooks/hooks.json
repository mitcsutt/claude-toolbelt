{
  "description": "PreToolUse: log every tool call. PostToolUse(Bash): detect sandbox/SSH/fs denials.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/log.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sandbox-watch.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
